# membego-web (Landing + Marketplace). Lectura pública; NUNCA service_role.

# Base de datos (misma que la app; se recomienda credencial de solo lectura)
DATABASE_URL="postgresql://...:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...:5432/postgres"

# Supabase (solo anon key — para getUser en promos privadas; NO service_role)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."

# Dominios (canónico público + enlace a la app)
NEXT_PUBLIC_APP_URL="https://membego.com"
NEXT_PUBLIC_APP_ORIGIN="https://app.membego.com"

# Instalación de @membego/ui desde GitHub Packages (token con read:packages)
# NODE_AUTH_TOKEN="ghp_...."

# Lanzamiento gradual del marketplace: slugs (separados por coma) de las
# empresas visibles en directorios públicos. Vacío = mostrar todas.
# Ej.: NEXT_PUBLIC_EMPRESAS_VISIBLES="car-town-wash"
NEXT_PUBLIC_EMPRESAS_VISIBLES=""
